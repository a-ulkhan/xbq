{
  "name": "xcode-build-queue",
  "version": "0.2.0",
  "description": "Serial build queue for Xcode projects with git worktrees",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a-ulkhan/xbq.git"
  },
  "keywords": [
    "xcode",
    "build",
    "queue",
    "worktree",
    "swift",
    "ios"
  ],
  "bin": {
    "xbq": "dist/cli.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "dev": "tsx src/cli.ts",
    "watch": "tsc --watch"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
